# Copy to `.env` (docker compose reads it automatically) and fill in values.
#   cp .env.example .env

# ---- Enables chat (DashScope / Qwen) ----
# Create a key at https://dashscope.console.aliyun.com/ . The container boots
# without it, but chat will not work until it is set.
DASHSCOPE_API_KEY=

# ---- Optional ----
# DashScope model id (default: qwen-max).
DATAAGENT_MODEL_NAME=qwen-max

# Host port for the web UI (default: 8080).
DATAAGENT_PORT=8080

# JWT signing secret, >= 32 chars. CHANGE THIS for any non-local deployment.
#   generate one:  openssl rand -base64 48
DATAAGENT_JWT_SECRET=dataagent-default-dev-secret-change-in-production-32chars

# Extra JVM flags, e.g. heap sizing: -Xms256m -Xmx1g
JAVA_OPTS=
